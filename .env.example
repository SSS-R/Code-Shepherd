# Code Shepherd Relay Server Environment Variables

# Server Configuration
PORT=3000

# Database
DATABASE_PATH=./relay.db

# Temporal.io Configuration
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=code-shepherd-queue

# Web Push Configuration (VAPID Keys)
# Generate new keys by running: cd packages/relay && npx ts-node src/utils/vapidKeys.ts
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Development
NODE_ENV=development

# Universal MCP Gateway
# These are operator/developer fallback settings.
# Normal end-user onboarding should use the pairing command generated in Settings.
RELAY_URL=http://localhost:3000
CONNECTOR_ID=openclaw-mcp
CONNECTOR_SECRET=replace_with_rotated_secret
AGENT_ID=codex-mcp-bridge
AGENT_NAME=Codex MCP Bridge
GATEWAY_ADAPTER=codex-proxy
AGENT_CAPABILITIES=mcp,codex,chat,bridge
HEARTBEAT_INTERVAL_MS=30000
COMMAND_POLL_INTERVAL_MS=2000
UPSTREAM_AGENT_COMMAND=
UPSTREAM_AGENT_ARGS=[]
UPSTREAM_AGENT_WORKDIR=
CODEX_CLI_PATH=
CODEX_MODEL=
CODEX_PROFILE=
CODEX_SANDBOX=workspace-write
CODEX_EXTRA_ARGS=[]
